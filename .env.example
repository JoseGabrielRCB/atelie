# ==========================================================================
# Variáveis de ambiente do backend do Ateliê
# Copie este arquivo para .env e ajuste os valores. NUNCA commite o .env.
# ==========================================================================

# Chave secreta do Django. Gere uma nova para produção, por exemplo:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=troque-esta-chave-em-producao

# Modo debug (True apenas em desenvolvimento)
DEBUG=True

# Hosts permitidos, separados por vírgula
ALLOWED_HOSTS=localhost,127.0.0.1

# --------------------------------------------------------------------------
# Banco de dados PostgreSQL (bate com o docker-compose.yml deste projeto)
# --------------------------------------------------------------------------
DB_NAME=atelie
DB_USER=atelie
DB_PASSWORD=atelie
# DB_HOST=localhost para rodar o Django fora do Docker (na sua máquina).
# Ao rodar tudo via "docker compose", o compose sobrescreve para DB_HOST=db.
DB_HOST=localhost
DB_PORT=5432

# --------------------------------------------------------------------------
# CORS — origem(ns) do frontend React, separadas por vírgula
# --------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --------------------------------------------------------------------------
# Superuser criado automaticamente pelo container do backend no 1º start.
# (Opcional — só usado pelo docker compose. Troque a senha!)
# --------------------------------------------------------------------------
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@atelie.local
DJANGO_SUPERUSER_PASSWORD=Atelie@2026

# --------------------------------------------------------------------------
# Frontend (Vite) — usado pelo serviço "frontend" do docker compose.
# O frontend tem seu próprio frontend/.env para rodar fora do Docker.
# --------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_WHATSAPP=5581990000000
