# ==========================================================================
# Variáveis de ambiente do backend do Ateliê
# Copie este arquivo para .env e ajuste os valores. NUNCA commite o .env.
# ==========================================================================

# Chave secreta do Django. Gere uma nova para produção, por exemplo:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=troque-esta-chave-em-producao

# Modo debug (True apenas em desenvolvimento)
DEBUG=True

# Hosts permitidos, separados por vírgula
# Inclua "backend" para webhooks internos do docker compose (Evolution -> Django).
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --------------------------------------------------------------------------
# Banco de dados PostgreSQL (bate com o docker-compose.yml deste projeto)
# --------------------------------------------------------------------------
DB_NAME=atelie
DB_USER=atelie
DB_PASSWORD=atelie
# DB_HOST=localhost para rodar o Django fora do Docker (na sua máquina).
# Ao rodar tudo via "docker compose", o compose sobrescreve para DB_HOST=db.
DB_HOST=localhost
DB_PORT=5432

# --------------------------------------------------------------------------
# CORS — origem(ns) do frontend React, separadas por vírgula
# --------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --------------------------------------------------------------------------
# Superuser criado automaticamente pelo container do backend no 1º start.
# (Opcional — só usado pelo docker compose. Troque a senha!)
# --------------------------------------------------------------------------
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@atelie.local
DJANGO_SUPERUSER_PASSWORD=Atelie@2026

# --------------------------------------------------------------------------
# Frontend (Vite) — usado pelo serviço "frontend" do docker compose.
# O frontend tem seu próprio frontend/.env para rodar fora do Docker.
# --------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_WHATSAPP=5581990000000

# --------------------------------------------------------------------------
# Pagamento online — Mercado Pago (Checkout Pro: Pix + cartão)
# Pegue as credenciais em https://www.mercadopago.com.br/developers
# Em desenvolvimento, use credenciais de TESTE. NUNCA commite valores reais.
# --------------------------------------------------------------------------
# Access token do servidor (TEST-... em dev, APP_USR-... em produção).
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000
# Segredo da assinatura do webhook (painel do MP > Webhooks > "Assinatura secreta").
MP_WEBHOOK_SECRET=troque-pelo-segredo-do-webhook
# Base HTTPS pública do backend para o MP chamar o webhook (notification_url).
# Em dev, use um túnel (ex.: ngrok): https://SEU-TUNEL.ngrok-free.app
MP_PUBLIC_URL=http://localhost:8000
# Base do frontend para as páginas de retorno (back_urls).
FRONTEND_URL=http://localhost:5173

# --------------------------------------------------------------------------
# Bot de WhatsApp do DONO (privado) — Evolution API (não-oficial / Baileys)
# Uso INTERNO: alertas de estoque e comandos do dono. NUNCA fala com clientes.
# ⚠️ Use um número de telefone DEDICADO para o bot — NUNCA o número principal
#    da loja (a API não-oficial tem risco de banimento do número).
# --------------------------------------------------------------------------
# URL base da Evolution API.
#   - Para chamadas a partir da MÁQUINA/HOST (curl, navegador): http://localhost:8080
#   - Para chamadas DE DENTRO da rede do compose (backend → Evolution): http://evolution-api:8080
EVOLUTION_URL=http://localhost:8080
# Chave global da Evolution (header "apikey"). Troque por um valor forte e secreto.
EVOLUTION_API_KEY=troque-por-uma-chave-forte
# Nome da instância do WhatsApp criada na Evolution.
EVOLUTION_INSTANCE=atelie-bot
# URL interna que a Evolution chama ao receber mensagens. No compose, o padrão
# é http://backend:8000/api/webhooks/whatsapp/.
EVOLUTION_WEBHOOK_URL=http://backend:8000/api/webhooks/whatsapp/
# Número(s) autorizado(s) do dono — separados por vírgula, só dígitos, formato
# internacional (DDI+DDD+número). Recebem alertas e podem comandar o bot.
WHATSAPP_DONO=5567999990000
# LID(s) autorizados só para ENTRADA, quando a Evolution entrega mensagens como
# 8712...@lid em vez do telefone. O envio continua usando WHATSAPP_DONO.
WHATSAPP_DONO_LID=
# Estoque baixo: variações com estoque <= este valor disparam alerta ao dono.
ESTOQUE_BAIXO_LIMIAR=1
# Versão do WhatsApp Web usada pelo Baileys (Evolution). Quando o WhatsApp
# invalida a versão embutida, o handshake dá timeout (408 "validating
# connection"), a instância fica em loop e o QR Code NUNCA aparece. Fixe aqui
# uma versão ATUAL (formato 2.3000.xxxxxxxxxx) e recrie o serviço:
#   docker compose up -d --force-recreate evolution-api
# Como descobrir a versão atual: veja a issue/README da Evolution API ou os
# projetos Baileys/WPPConnect (a versão muda com frequência).
EVOLUTION_WA_VERSION=2.3000.1035194821
