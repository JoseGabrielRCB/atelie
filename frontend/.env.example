# URL base do backend (sem barra no final). O cliente consome VITE_API_URL + /api/
VITE_API_URL=http://127.0.0.1:8000

# Número do WhatsApp do ateliê em formato internacional, SÓ DÍGITOS.
# Ex.: 5581990000000 (55 = Brasil, 81 = DDD, restante = número).
# >>> PLACEHOLDER: troque pelo número real do ateliê. <<<
VITE_WHATSAPP=5581990000000
